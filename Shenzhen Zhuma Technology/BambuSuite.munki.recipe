<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Comment</key>
	<string>Imports the latest Bambu Suite into a Munki repo. IMPORTANT: the pkginfo version is set explicitly to %version% (parsed from the DMG URL by the parent download recipe, e.g. 01.02.02.00). Do not let it derive from the app bundle — CFBundleVersion is "1" and CFBundleShortVersionString is prefixed "Bambu Suite ", either of which produces a bad Munki version. MunkiImporter still auto-detects the app in the DMG to build the installs/copy_from_dmg items.</string>
	<key>Description</key>
	<string>Downloads the latest version of Bambu Suite and imports it into Munki.</string>
	<key>Identifier</key>
	<string>com.supportplan.autopkg.munki.BambuSuite</string>
	<key>ParentRecipe</key>
	<string>com.supportplan.autopkg.download.BambuSuite</string>
	<key>MinimumVersion</key>
	<string>2.3</string>
	<key>Input</key>
	<dict>
		<key>NAME</key>
		<string>BambuSuite</string>
		<key>MUNKI_REPO_SUBDIR</key>
		<string>apps/%NAME%</string>
		<key>pkginfo</key>
		<dict>
			<key>catalogs</key>
			<array>
				<string>testing</string>
			</array>
			<key>category</key>
			<string>Productivity</string>
			<key>description</key>
			<string>Bambu Lab's all-in-one software suite for 3D printing, laser cutting, blade cutting and pen drawing.</string>
			<key>developer</key>
			<string>Bambu Lab</string>
			<key>display_name</key>
			<string>Bambu Suite</string>
			<key>minimum_os_version</key>
			<string>11.0</string>
			<key>name</key>
			<string>%NAME%</string>
			<key>unattended_install</key>
			<true/>
			<key>unattended_uninstall</key>
			<true/>
			<key>version</key>
			<string>%version%</string>
		</dict>
	</dict>
	<key>Process</key>
	<array>
		<dict>
			<key>Processor</key>
			<string>MunkiImporter</string>
			<key>Arguments</key>
			<dict>
				<key>pkg_path</key>
				<string>%pathname%</string>
				<key>repo_subdirectory</key>
				<string>%MUNKI_REPO_SUBDIR%</string>
				<key>additional_makepkginfo_options</key>
				<array>
					<string>--mode</string>
					<string>ug+w,o-w</string>
				</array>
			</dict>
		</dict>
	</array>
</dict>
</plist>
